# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Lokalnie (docker-compose): postgres://writermate:writermate_dev@localhost:5432/writermate
# Vercel Postgres: wypełnij po provisionowaniu
DATABASE_URL=postgres://writermate:writermate_dev@localhost:5432/writermate
POSTGRES_PASSWORD=writermate_dev

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Sidecar URLs (lokalnie) ──────────────────────────────────────────────────
# HTTP API markitdown
MARKITDOWN_URL=http://localhost:8000
# MCP SSE endpoints (dla VS Code / agentów)
MARKITDOWN_MCP_URL=http://localhost:8001/sse
BASHTOOL_MCP_URL=http://localhost:8002/sse

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
